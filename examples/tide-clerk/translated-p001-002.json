      "pdf_page": 2,
      "display_page": 1,
      "source": "(not looking up)",
      "translation": "（没有抬头）"
    },
    {
      "id": "p001-e010",
      "type": "dialogue",
      "pdf_page": 2,
      "display_page": 1,
      "source": "The tide came early again.",
      "translation": "潮水又提前来了。"
